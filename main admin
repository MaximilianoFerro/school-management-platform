              { rol:"Administrador", desc:"Acceso completo: alumnos, docentes, comunicados, configuración.", color:"#4C3D9E", cant:2 },
              { rol:"Docente",       desc:"Carga de notas y asistencia, vista de sus cursos y comunicados.", color:"#3B82F6", cant:6 },
              { rol:"Familia",       desc:"Consulta de notas, asistencia, comunicados y agenda de su hijo.", color:"#10B981", cant:9 },
            ].map(r=>(
              <div key={r.rol} style={{ display:"flex", alignItems:"center", gap:16, background:"#FAFAFA", borderRadius:12, padding:"16px 20px", border:"1px solid #F0EEF8" }}>
                <div style={{ width:42, height:42, borderRadius:12, background:r.color+"18", display:"flex", alignItems:"center", justifyContent:"center", fontSize:18, flexShrink:0 }}>
                  {r.rol==="Administrador"?"🔑":r.rol==="Docente"?"👩‍🏫":"👨‍👩‍👧"}
                </div>
                <div style={{ flex:1 }}>
                  <div style={{ fontSize:14, fontWeight:700, color:"#1A1535" }}>{r.rol}</div>
                  <div style={{ fontSize:12, color:"#9CA3AF" }}>{r.desc}</div>
                </div>
                <Badge label={`${r.cant} usuarios`} color={r.color}/>
              </div>
            ))}
          </div>
          <div style={{ marginTop:20 }}>
            <BtnPrimary>+ Invitar usuario</BtnPrimary>
          </div>
        </Card>
      )}

      {tab==="seguridad" && (
        <Card style={{ padding:24 }}>
          <h4 style={{ margin:"0 0 18px", fontSize:13, fontWeight:700, color:"#9CA3AF", textTransform:"uppercase", letterSpacing:1 }}>Seguridad de la cuenta</h4>
          <div style={{ display:"flex", flexDirection:"column", gap:16, maxWidth:440 }}>
            <FormRow label="Contraseña actual"><Input placeholder="••••••••" style={{ width:"100%" }}/></FormRow>
            <FormRow label="Nueva contraseña"><Input placeholder="••••••••" style={{ width:"100%" }}/></FormRow>
            <FormRow label="Confirmar nueva contraseña"><Input placeholder="••••••••" style={{ width:"100%" }}/></FormRow>
            <BtnPrimary>Actualizar contraseña</BtnPrimary>
          </div>
        </Card>
      )}
    </div>
  );
};


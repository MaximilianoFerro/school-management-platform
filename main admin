// VISTA: REPORTES
// ══════════════════════════════════════════════════════════════════════════════
const Reportes = () => {
  const activos = ALUMNOS_DATA.filter(a=>a.estado==="activo");
  const porNivel = activos.reduce((acc,a)=>{ acc[a.nivel]=(acc[a.nivel]||0)+1; return acc; }, {});

  const rendimiento = activos.map(a=>({ nombre:a.nombre.split(" ")[0]+" "+a.nombre.split(" ")[1][0]+".", prom:promAlumno(a.id), nivel:a.nivel }))
    .filter(x=>x.prom!==null)
    .sort((a,b)=>b.prom-a.prom);

  const promPorNivel = Object.keys(porNivel).map(nivel=>{
    const als = activos.filter(a=>a.nivel===nivel && promAlumno(a.id)!==null);
    const p = (als.reduce((s,a)=>s+promAlumno(a.id),0)/als.length).toFixed(1);
    return { nivel, prom:parseFloat(p) };
  });

  const RANGOS = [["9-10","#10B981"],[" 7-8","#3B82F6"],["5-6","#F59E0B"],["< 5","#EF4444"]];
  const rangoCounts = activos.reduce((acc,a)=>{
    const p=promAlumno(a.id); if(!p) return acc;
    if(p>=9) acc[0]++;
    else if(p>=7) acc[1]++;
    else if(p>=5) acc[2]++;
    else acc[3]++;
    return acc;
  }, [0,0,0,0]);

  return (
    <div>
      <SectionHeader title="Reportes" subtitle="Resumen académico del ciclo lectivo 2025"/>

      <div style={{ display:"grid", gridTemplateColumns:"repeat(3,1fr)", gap:14, marginBottom:24 }}>
        {promPorNivel.map(({nivel,prom})=>(
          <Card key={nivel} style={{ padding:22, textAlign:"center" }}>
            <div style={{ fontSize:32, fontWeight:800, color:NIVEL_COLOR[nivel] }}>{prom}</div>
            <div style={{ fontSize:13, color:"#6B7280", marginTop:2 }}>Promedio {nivel}</div>
            <div style={{ height:4, background:"#F3F4F6", borderRadius:4, margin:"12px 0 4px" }}>
              <div style={{ height:4, width:`${(prom/10)*100}%`, background:NIVEL_COLOR[nivel], borderRadius:4 }}/>
            </div>
            <div style={{ fontSize:11, color:NIVEL_COLOR[nivel], fontWeight:600 }}>{porNivel[nivel]} alumnos</div>
          </Card>
        ))}
      </div>

      <div style={{ display:"grid", gridTemplateColumns:"1fr 1.5fr", gap:20, marginBottom:20 }}>
        <Card style={{ padding:22 }}>
          <h3 style={{ margin:"0 0 18px", fontSize:14, fontWeight:700, color:"#1A1535" }}>Distribución de rendimiento</h3>
          {RANGOS.map(([label,color],i)=>{
            const c = rangoCounts[i];
            const p2 = pct(c, activos.length);
            return (
              <div key={label} style={{ marginBottom:12 }}>
                <div style={{ display:"flex", justifyContent:"space-between", fontSize:12, marginBottom:4 }}>
                  <span style={{ color:"#374151", fontWeight:600 }}>Nota {label}</span>
                  <span style={{ color, fontWeight:700 }}>{c} alumnos ({p2}%)</span>
                </div>
                <div style={{ height:8, background:"#F3F4F6", borderRadius:4 }}>
                  <div style={{ height:8, width:`${p2}%`, background:color, borderRadius:4 }}/>
                </div>
              </div>
            );
          })}
        </Card>

        <Card style={{ padding:22 }}>
          <h3 style={{ margin:"0 0 18px", fontSize:14, fontWeight:700, color:"#1A1535" }}>Ranking de rendimiento</h3>
          <div style={{ display:"flex", flexDirection:"column", gap:8 }}>
            {rendimiento.slice(0,7).map((a,i)=>{
              const col = a.prom>=7?"#10B981":a.prom>=6?"#F59E0B":"#EF4444";
              return (
                <div key={a.nombre} style={{ display:"flex", alignItems:"center", gap:10 }}>
                  <div style={{ width:22, textAlign:"center", fontSize:12, fontWeight:800, color:i<3?"#F59E0B":"#9CA3AF" }}>{i+1}</div>
                  <div style={{ flex:1, fontSize:13, fontWeight:600, color:"#374151" }}>{a.nombre}</div>
                  <Badge label={a.nivel} color={NIVEL_COLOR[a.nivel]} small/>
                  <span style={{ fontSize:15, fontWeight:800, color:col, minWidth:28, textAlign:"right" }}>{a.prom}</span>
                </div>
              );
            })}
          </div>
        </Card>
      </div>

      <Card style={{ padding:22 }}>
        <h3 style={{ margin:"0 0 18px", fontSize:14, fontWeight:700, color:"#1A1535" }}>Asistencia por alumno</h3>
        <div style={{ display:"grid", gridTemplateColumns:"repeat(2,1fr)", gap:8 }}>
          {activos.map(a=>{
            const ap=pct(ASISTENCIA_DATA[a.id].presentes,ASISTENCIA_DATA[a.id].total);
            const ac=ap>=85?"#10B981":ap>=75?"#F59E0B":"#EF4444";
            return (
              <div key={a.id} style={{ display:"flex", alignItems:"center", gap:10 }}>
                <Avatar ini={a.ini} size={28}/>
                <div style={{ flex:1 }}>
                  <div style={{ fontSize:12, fontWeight:600, color:"#374151" }}>{a.nombre.split(" ")[0]} {a.nombre.split(" ")[1]}</div>
                  <div style={{ height:4, background:"#F3F4F6", borderRadius:2, marginTop:3 }}>
                    <div style={{ height:4, width:`${ap}%`, background:ac, borderRadius:2 }}/>
                  </div>
                </div>
                <span style={{ fontSize:12, fontWeight:700, color:ac, minWidth:32, textAlign:"right" }}>{ap}%</span>
              </div>
            );
          })}
        </div>
      </Card>
    </div>
  );
};


const AttendanceCalendar = ({ alumnoId }) => {
  const [calData, setCalData] = useState({ ...(ASISTENCIA_CAL_INIT[alumnoId] || {}) });
  const [mesOffset, setMesOffset] = useState(0); // 0 = Jun 2025, -1 = May, -2 = Apr

  const BASE_YEAR = 2025, BASE_MONTH = 5; // June = index 5
  const mesIdx   = ((BASE_MONTH + mesOffset) % 12 + 12) % 12;
  const yearVal  = BASE_YEAR + Math.floor((BASE_MONTH + mesOffset) / 12);
  const MESES_ES = ["Enero","Febrero","Marzo","Abril","Mayo","Junio","Julio","Agosto","Septiembre","Octubre","Noviembre","Diciembre"];
  const DIAS_ES  = ["Lun","Mar","Mié","Jue","Vie","Sáb","Dom"];

  // Build calendar grid
  const firstDay  = new Date(yearVal, mesIdx, 1);
  const lastDay   = new Date(yearVal, mesIdx + 1, 0);
  const startDow  = (firstDay.getDay() + 6) % 7; // Monday = 0
  const totalDays = lastDay.getDate();

  const cells = [];
  for (let i = 0; i < startDow; i++) cells.push(null);
  for (let d = 1; d <= totalDays; d++) cells.push(d);
  while (cells.length % 7 !== 0) cells.push(null);

  const isWeekend = (d) => {
    if (!d) return false;
    const dow = new Date(yearVal, mesIdx, d).getDay();
    return dow === 0 || dow === 6;
  };

  const toKey = (d) => {
    const mm = String(mesIdx + 1).padStart(2,"0");
    const dd = String(d).padStart(2,"0");
    return `${yearVal}-${mm}-${dd}`;
  };

  const toggle = (d) => {
    if (!d || isWeekend(d)) return;
    const key = toKey(d);
    const cur = calData[key];
    setCalData(prev => {
      const next = { ...prev };
      if (!cur)            next[key] = "ausente";
      else if (cur === "ausente")  next[key] = "tardanza";
      else                  delete next[key];
      return next;
    });
  };

  // Stats from calendar for this month
  const monthKeys = Object.keys(calData).filter(k => k.startsWith(`${yearVal}-${String(mesIdx+1).padStart(2,"0")}`));
  const ausMonth   = monthKeys.filter(k => calData[k]==="ausente").length;
  const tardMonth  = monthKeys.filter(k => calData[k]==="tardanza").length;
  const allAus     = Object.values(calData).filter(v=>v==="ausente").length;
  const allTard    = Object.values(calData).filter(v=>v==="tardanza").length;

  // Count school days this month
  let schoolDays = 0;
  for (let d = 1; d <= totalDays; d++) { if (!isWeekend(d)) schoolDays++; }
  const presentMonth = schoolDays - ausMonth - tardMonth;

  const cellStyle = (d) => {
    if (!d) return { background:"transparent", border:"none", cursor:"default" };
    const key = toKey(d);
    const st  = calData[key];
    const wk  = isWeekend(d);
    const today = new Date(2025,5,5); // fixed "today" for demo
    const thisDay = new Date(yearVal, mesIdx, d);
    const isFuture = thisDay > today;

    let bg = "#F9F9FC", borderColor = "#E5E3F5", color = "#374151";
    if (wk)               { bg="#F5F5F7"; borderColor="#EBEBEF"; color="#C0BDD0"; }
    else if (isFuture)    { bg="#FAFAFA"; borderColor="#EBEBEF"; color="#C0BDD0"; }
    else if (st==="ausente")  { bg="#FEF2F2"; borderColor="#FCA5A5"; color="#EF4444"; }
    else if (st==="tardanza") { bg="#FFFBEB"; borderColor="#FCD34D"; color="#D97706"; }
    else                  { bg="#F0FDF4"; borderColor="#BBF7D0"; color="#15803D"; }

    return { background:bg, borderColor, color, cursor: (wk||isFuture)?"default":"pointer" };
  };

  return (
    <div>
      {/* Month navigation */}
      <Card style={{ padding:24, marginBottom:16 }}>
        <div style={{ display:"flex", alignItems:"center", justifyContent:"space-between", marginBottom:20 }}>
          <button onClick={()=>setMesOffset(m=>Math.max(m-1,-3))} disabled={mesOffset<=-3}
            style={{ background:"#F5F4FC", border:"none", borderRadius:8, width:34, height:34, cursor:"pointer", fontSize:16, color:mesOffset<=-3?"#D1C9F0":"#4C3D9E", fontWeight:700 }}>‹</button>
          <h3 style={{ margin:0, fontSize:17, fontWeight:800, color:"#1A1535" }}>{MESES_ES[mesIdx]} {yearVal}</h3>
          <button onClick={()=>setMesOffset(m=>Math.min(m+1,0))} disabled={mesOffset>=0}
            style={{ background:"#F5F4FC", border:"none", borderRadius:8, width:34, height:34, cursor:"pointer", fontSize:16, color:mesOffset>=0?"#D1C9F0":"#4C3D9E", fontWeight:700 }}>›</button>
        </div>

        {/* Day headers */}
        <div style={{ display:"grid", gridTemplateColumns:"repeat(7,1fr)", gap:4, marginBottom:4 }}>
          {DIAS_ES.map((d,i)=>(
            <div key={d} style={{ textAlign:"center", fontSize:11, fontWeight:700, color: i>=5?"#C0BDD0":"#9CA3AF", padding:"6px 0", textTransform:"uppercase", letterSpacing:"0.5px" }}>{d}</div>
          ))}
        </div>

        {/* Calendar grid */}
        <div style={{ display:"grid", gridTemplateColumns:"repeat(7,1fr)", gap:4 }}>
          {cells.map((d,i)=>{
            const cs = cellStyle(d);
            const st = d ? calData[toKey(d)] : null;
            return (
              <div key={i} onClick={()=>toggle(d)}
                style={{ border:`1.5px solid ${cs.borderColor}`, background:cs.background, borderRadius:8, aspectRatio:"1", display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"center", cursor:cs.cursor, transition:"all 0.12s", minHeight:36 }}>
                {d && <>
                  <span style={{ fontSize:13, fontWeight: st?"800":"500", color:cs.color, lineHeight:1 }}>{d}</span>
                  {st==="ausente"  && <span style={{ fontSize:8,  fontWeight:800, color:"#EF4444", letterSpacing:"0.5px", marginTop:1 }}>AUS</span>}
                  {st==="tardanza" && <span style={{ fontSize:8,  fontWeight:800, color:"#D97706", letterSpacing:"0.5px", marginTop:1 }}>TARD</span>}
                  {!st && !isWeekend(d) && (() => { const f = new Date(yearVal,mesIdx,d) > new Date(2025,5,5); return !f ? <span style={{ fontSize:7, color:"#86EFAC", marginTop:1 }}>✓</span> : null; })()}
                </>}
              </div>
            );
          })}
        </div>

        {/* Legend + tip */}
        <div style={{ display:"flex", alignItems:"center", gap:16, marginTop:16, paddingTop:14, borderTop:"1px solid #F0EEF8", flexWrap:"wrap" }}>
          {[["#F0FDF4","#BBF7D0","#15803D","Presente"],["#FEF2F2","#FCA5A5","#EF4444","Ausente"],["#FFFBEB","#FCD34D","#D97706","Tardanza"],["#F5F5F7","#EBEBEF","#C0BDD0","No lectivo"]].map(([bg,brd,col,lbl])=>(
            <div key={lbl} style={{ display:"flex", alignItems:"center", gap:6 }}>
              <div style={{ width:16, height:16, borderRadius:4, background:bg, border:`1.5px solid ${brd}` }}/>
              <span style={{ fontSize:11, color:"#6B7280", fontWeight:500 }}>{lbl}</span>
            </div>
          ))}
          <span style={{ marginLeft:"auto", fontSize:11, color:"#C4B9F0", fontStyle:"italic" }}>Clic para cambiar estado</span>
        </div>
      </Card>

      {/* Stats del mes + acumulado */}
      <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:14 }}>
        <Card style={{ padding:20 }}>
          <div style={{ fontSize:11, fontWeight:700, color:"#9CA3AF", textTransform:"uppercase", letterSpacing:1, marginBottom:14 }}>{MESES_ES[mesIdx]} {yearVal}</div>
          <div style={{ display:"grid", gridTemplateColumns:"repeat(3,1fr)", gap:10 }}>
            {[["Presentes",presentMonth,"#10B981"],["Ausentes",ausMonth,"#EF4444"],["Tardanzas",tardMonth,"#F59E0B"]].map(([k,v,c])=>(
              <div key={k} style={{ textAlign:"center", background:c+"10", borderRadius:10, padding:"12px 8px" }}>
                <div style={{ fontSize:22, fontWeight:800, color:c }}>{v}</div>
                <div style={{ fontSize:10, color:"#9CA3AF", marginTop:2 }}>{k}</div>
              </div>
            ))}
          </div>
        </Card>
        <Card style={{ padding:20 }}>
          <div style={{ fontSize:11, fontWeight:700, color:"#9CA3AF", textTransform:"uppercase", letterSpacing:1, marginBottom:14 }}>Acumulado del ciclo</div>
          <div style={{ display:"grid", gridTemplateColumns:"repeat(2,1fr)", gap:10, marginBottom:12 }}>
            {[["Ausencias",allAus,"#EF4444"],["Tardanzas",allTard,"#F59E0B"]].map(([k,v,c])=>(
              <div key={k} style={{ textAlign:"center", background:c+"10", borderRadius:10, padding:"12px 8px" }}>
                <div style={{ fontSize:22, fontWeight:800, color:c }}>{v}</div>
                <div style={{ fontSize:10, color:"#9CA3AF", marginTop:2 }}>{k}</div>
              </div>
            ))}
          </div>
          <div style={{ fontSize:12, color: allAus>=7?"#EF4444":allAus>=4?"#D97706":"#10B981", fontWeight:600, padding:"8px 12px", background: allAus>=7?"#FEF2F2":allAus>=4?"#FFFBEB":"#F0FDF4", borderRadius:8 }}>
            {allAus>=7?"🚨 Asistencia crítica":allAus>=4?"⚠️ Monitorear ausencias":"✅ Asistencia regular"}
          </div>
        </Card>
      </div>
    </div>
  );
};

// ── Grade table base components ───────────────────────────────────────────────
const BIM_LABELS = { "1B":"1° Bimestre","2B":"2° Bimestre","3B":"3° Bimestre","4B":"4° Bimestre" };
const BIM_BG     = { "1B":"#22195A","2B":"#2E2472","3B":"#22195A","4B":"#2E2472" };
const noteColor  = v => v===null||v===undefined?"#9CA3AF":v>=7?"#10B981":v>=6?"#F59E0B":"#EF4444";

const TH = ({ children, style, ...rest }) => (
  <th {...rest} style={{ padding:"8px 4px", textAlign:"center", fontSize:10, fontWeight:700, letterSpacing:"0.5px", textTransform:"uppercase", border:"1px solid rgba(255,255,255,0.12)", ...style }}>{children}</th>
);
const TD = ({ children, style, ...rest }) => (
  <td {...rest} style={{ padding:"5px 4px", textAlign:"center", border:"1.5px solid #DDD8F5", ...style }}>{children}</td>
);

// ── Alumno Detalle ────────────────────────────────────────────────────────────
const AlumnoDetalle = ({ alumno, onBack }) => {
  const [mainTab,  setMainTab]  = useState("notas");
  const [notasTab, setNotasTab] = useState("Q1");
  const [locks, setLocks] = useState({ "1B":true, "2B":false, "3B":false, "4B":false });
  const toggleLock = bim => setLocks(prev => ({ ...prev, [bim]: !prev[bim] }));

  const p      = promAlumno(alumno.id);
  const asist  = ASISTENCIA_DATA[alumno.id];
  const ap     = pct(asist.presentes, asist.total);
  const materias = MATERIAS_POR_NIVEL[alumno.nivel] || [];
  const baseNotas = NOTAS_DATA[alumno.id] || {};

  const [notasState, setNotasState] = useState(() =>
    materias.reduce((acc, mat) => {
      const md = baseNotas[mat] || {};
      acc[mat] = {
        "1B": [...(md["1B"] || [null,null,null,null])],
        "2B": [...(md["2B"] || [null,null,null,null])],
        "3B": [...(md["3B"] || [null,null,null,null])],
        "4B": [...(md["4B"] || [null,null,null,null])],
      };
      return acc;
    }, {})
  );

  const setNota = (mat, bim, idx, val) => {
    if (locks[bim]) return;
    const parsed = val===""?null: isNaN(Number(val))?val: Math.min(10,Math.max(0,Number(val)));
    setNotasState(prev => {
      const arr = [...(prev[mat]?.[bim]||[null,null,null,null])];
      arr[idx] = parsed;
      return { ...prev, [mat]: { ...prev[mat], [bim]: arr } };
    });
  };

  const cierreBim = (mat, bim) => {
    const ns = (notasState[mat]?.[bim]||[]).filter(x=>typeof x==="number");
    return ns.length===4 ? parseFloat((ns.reduce((a,b)=>a+b,0)/4).toFixed(1)) : null;
  };
  const cierreQ = (mat, b1, b2) => {
    const c1=cierreBim(mat,b1), c2=cierreBim(mat,b2);
    return c1!==null&&c2!==null ? parseFloat(((c1+c2)/2).toFixed(1)) : null;
  };
  const notaFinal = mat => {
    const q1=cierreQ(mat,"1B","2B"), q2=cierreQ(mat,"3B","4B");
    return q1!==null&&q2!==null ? parseFloat(((q1+q2)/2).toFixed(1)) : null;
  };

  // ── Input cell ──
  const NoteInput = ({ mat, bim, idx }) => {
    const v = notasState[mat]?.[bim]?.[idx];
    const nc = typeof v==="number" ? noteColor(v) : "#C4B9F0";
    const locked = locks[bim];
    return (
      <input type="text" value={v??""} onChange={e=>setNota(mat,bim,idx,e.target.value)}
        disabled={locked} placeholder="—"
        style={{ width:38, height:32, border:`1.5px solid ${locked?"#E9E7F5":v!==null?nc+"55":"#D1C9F0"}`, borderRadius:6, textAlign:"center", fontSize:14, fontWeight:800, color:locked?"#C4B9F0":nc, background:locked?"#F5F4FC":typeof v==="number"?nc+"10":"#fff", fontFamily:"inherit", outline:"none", cursor:locked?"not-allowed":"text", padding:0 }}
      />
    );
  };

  const CierreCell = ({ val }) => (
    <TD style={{ background:val!==null?noteColor(val)+"10":"#F9F8FF", borderLeft:"2px solid #C4B9F0", borderRight:"2px solid #C4B9F0" }}>
      {val!==null?<span style={{ fontSize:14,fontWeight:800,color:noteColor(val) }}>{val}</span>:<span style={{ color:"#D1D5DB",fontSize:11 }}>—</span>}
    </TD>
  );
  const CierreQCell = ({ val, big }) => (
    <TD style={{ background:val!==null?noteColor(val)+"18":"#EEE9FC", border:"2px solid #C4B9F0" }}>
      {val!==null?<span style={{ fontSize:big?16:14,fontWeight:900,color:noteColor(val) }}>{val}</span>:<span style={{ color:"#D1D5DB",fontSize:11 }}>—</span>}
    </TD>
  );

  const LockBtn = ({ bim }) => (
    <button onClick={()=>toggleLock(bim)}
      style={{ background:locks[bim]?"rgba(239,68,68,0.25)":"rgba(16,185,129,0.25)", border:`1px solid ${locks[bim]?"rgba(239,68,68,0.5)":"rgba(16,185,129,0.5)"}`, borderRadius:6, padding:"3px 9px", cursor:"pointer", display:"flex", alignItems:"center", gap:5, color:"#fff", fontSize:11, fontWeight:700 }}>
      <span style={{ fontSize:13 }}>{locks[bim]?"🔒":"🔓"}</span>{locks[bim]?"Bloqueado":"Editable"}
    </button>
  );

  // ── Cuatrimestre table ──
  const CuatTable = ({ bims, qLabel }) => {
    const [b1,b2] = bims;
    return (
      <div style={{ overflowX:"auto" }}>
        <table style={{ width:"100%", borderCollapse:"collapse", tableLayout:"fixed", minWidth:820 }}>
          <colgroup>
            <col style={{ width:"17%" }}/>
            <col style={{ width:"5.5%" }}/><col style={{ width:"5.5%" }}/><col style={{ width:"5.5%" }}/><col style={{ width:"5.5%" }}/><col style={{ width:"7%" }}/>
            <col style={{ width:"5.5%" }}/><col style={{ width:"5.5%" }}/><col style={{ width:"5.5%" }}/><col style={{ width:"5.5%" }}/><col style={{ width:"7%" }}/>
            <col style={{ width:"9%" }}/>
          </colgroup>
          <thead>
            <tr>
              <TH rowSpan={2} style={{ background:"#1A1535", color:"#fff", textAlign:"left", padding:"10px 14px", fontSize:11 }}>MATERIA</TH>
              {bims.map(bim=>(
                <th key={bim} colSpan={5} style={{ background:BIM_BG[bim], border:"1px solid rgba(255,255,255,0.1)", padding:"8px 12px" }}>
                  <div style={{ display:"flex", alignItems:"center", justifyContent:"space-between" }}>
                    <span style={{ color:"#fff", fontSize:12, fontWeight:800 }}>{BIM_LABELS[bim]}</span>
                    <LockBtn bim={bim}/>
                  </div>
                </th>
              ))}
              <TH rowSpan={2} style={{ background:"#4C3D9E", color:"#fff", lineHeight:1.3 }}>CIERRE<br/>{qLabel}</TH>
            </tr>
            <tr>
              {bims.flatMap(bim=>[
                ...["N1","N2","N3","N4"].map(n=><TH key={`${bim}-${n}`} style={{ background:"#F0EDF8",color:"#4C3D9E" }}>{n}</TH>),
                <TH key={`${bim}-c`} style={{ background:"#E4DFFA",color:"#4C3D9E",fontWeight:800 }}>CIERRE</TH>
              ])}
            </tr>
          </thead>
          <tbody>
            {materias.map((mat,ri)=>{
              const cb1=cierreBim(mat,b1), cb2=cierreBim(mat,b2), cq=cierreQ(mat,b1,b2);
              const rowBg=ri%2===0?"#fff":"#FBFAFF";
              return (
                <tr key={mat} style={{ background:rowBg }}>
                  <td style={{ padding:"0 14px", height:46, border:"1.5px solid #DDD8F5", borderLeft:"3px solid #C4B9F0", background:rowBg }}>
                    <span style={{ fontSize:13,fontWeight:600,color:"#1A1535" }}>{mat}</span>
                  </td>
                  {bims.flatMap(bim=>[
                    ...[0,1,2,3].map(j=>(
                      <TD key={`${bim}-${j}`} style={{ background:locks[bim]?"#F5F4FC":rowBg }}>
                        <NoteInput mat={mat} bim={bim} idx={j}/>
                      </TD>
                    )),
                    <CierreCell key={`${bim}-c`} val={bim===b1?cb1:cb2}/>
                  ])}
                  <CierreQCell val={cq}/>
                </tr>
              );
            })}
            {/* Footer */}
            <tr style={{ background:"#F5F4FC", borderTop:"2px solid #C4B9F0" }}>
              <td style={{ padding:"8px 14px", border:"1.5px solid #DDD8F5", fontSize:10, fontWeight:800, color:"#4C3D9E", textTransform:"uppercase", letterSpacing:"0.5px" }}>Promedio grupo</td>
              {bims.flatMap(bim=>[
                ...[0,1,2,3].map(j=>{
                  const ns=materias.map(m=>notasState[m]?.[bim]?.[j]).filter(x=>typeof x==="number");
                  const ca=ns.length?parseFloat((ns.reduce((a,b)=>a+b,0)/ns.length).toFixed(1)):null;
                  return <TD key={`f-${bim}-${j}`} style={{ background:"transparent" }}>{ca!==null?<span style={{ fontSize:12,fontWeight:700,color:noteColor(ca) }}>{ca}</span>:<span style={{ color:"#E5E7EB" }}>—</span>}</TD>;
                }),
                (()=>{ const cs=materias.map(m=>cierreBim(m,bim)).filter(x=>x!==null); const ca=cs.length?parseFloat((cs.reduce((a,b)=>a+b,0)/cs.length).toFixed(1)):null; return <CierreCell key={`f-${bim}-c`} val={ca}/>; })()
              ])}
              {(()=>{ const cqs=materias.map(m=>cierreQ(m,b1,b2)).filter(x=>x!==null); const ca=cqs.length?parseFloat((cqs.reduce((a,b)=>a+b,0)/cqs.length).toFixed(1)):null; return <CierreQCell val={ca}/>; })()}
            </tr>
          </tbody>
        </table>
      </div>
    );
  };

  // ── Resumen table ──
  const ResumenTable = () => (
    <div style={{ overflowX:"auto" }}>
      <table style={{ width:"100%", borderCollapse:"collapse", tableLayout:"fixed", minWidth:660 }}>
        <colgroup>
          <col style={{ width:"20%" }}/>
          <col style={{ width:"9%" }}/><col style={{ width:"9%" }}/><col style={{ width:"11%" }}/>
          <col style={{ width:"9%" }}/><col style={{ width:"9%" }}/><col style={{ width:"11%" }}/>
          <col style={{ width:"12%" }}/>
        </colgroup>
        <thead>
          <tr>
            <TH rowSpan={2} style={{ background:"#1A1535", color:"#fff", textAlign:"left", padding:"10px 14px" }}>MATERIA</TH>
            <th colSpan={3} style={{ background:"#22195A", border:"1px solid rgba(255,255,255,0.1)", padding:"8px", color:"#fff", fontSize:12, fontWeight:800, textAlign:"center" }}>1° Cuatrimestre</th>
            <th colSpan={3} style={{ background:"#2E2472", border:"1px solid rgba(255,255,255,0.1)", padding:"8px", color:"#fff", fontSize:12, fontWeight:800, textAlign:"center" }}>2° Cuatrimestre</th>
            <TH rowSpan={2} style={{ background:"#1A1535", color:"#fff", lineHeight:1.3 }}>NOTA<br/>FINAL</TH>
          </tr>
          <tr>
            {["Cierre 1°Bim","Cierre 2°Bim","Cierre 1°C","Cierre 3°Bim","Cierre 4°Bim","Cierre 2°C"].map(h=>(
              <TH key={h} style={{ background:"#E4DFFA", color:"#4C3D9E", fontSize:9 }}>{h}</TH>
            ))}
          </tr>
        </thead>
        <tbody>
          {materias.map((mat,ri)=>{
            const c1=cierreBim(mat,"1B"),c2=cierreBim(mat,"2B"),c3=cierreBim(mat,"3B"),c4=cierreBim(mat,"4B");
            const cq1=cierreQ(mat,"1B","2B"),cq2=cierreQ(mat,"3B","4B"),nf=notaFinal(mat);
            const rowBg=ri%2===0?"#fff":"#FBFAFF";
            const cell=(v)=>v!==null?<span style={{ fontSize:13,fontWeight:700,color:noteColor(v) }}>{v}</span>:<span style={{ color:"#D1D5DB",fontSize:11 }}>—</span>;
            return (
              <tr key={mat} style={{ background:rowBg }}>
                <td style={{ padding:"0 14px",height:46,border:"1.5px solid #DDD8F5",borderLeft:"3px solid #C4B9F0",background:rowBg }}>
                  <span style={{ fontSize:13,fontWeight:600,color:"#1A1535" }}>{mat}</span>
                </td>
                <CierreCell val={c1}/><CierreCell val={c2}/>
                <CierreQCell val={cq1}/>
                <CierreCell val={c3}/><CierreCell val={c4}/>
                <CierreQCell val={cq2}/>
                <TD style={{ background:nf!==null?noteColor(nf)+"18":"#EEE9FC",border:"2px solid #9B7DE8" }}>
                  {nf!==null?<span style={{ fontSize:16,fontWeight:900,color:noteColor(nf) }}>{nf}</span>:<span style={{ color:"#D1D5DB" }}>—</span>}
                </TD>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  );

  return (
    <div>
      <BackBtn onClick={onBack}/>
      <div style={{ background:"linear-gradient(135deg,#1A1535 0%,#4C3D9E 100%)", borderRadius:20, padding:"28px 32px", marginBottom:22, color:"#fff" }}>
        <div style={{ display:"flex", alignItems:"center", gap:20 }}>
          <Avatar ini={alumno.ini} size={64}/>
          <div style={{ flex:1 }}>
            <div style={{ display:"flex", alignItems:"center", gap:10, marginBottom:4 }}>
              <h2 style={{ margin:0, fontSize:22, fontWeight:800 }}>{alumno.nombre}</h2>
              <Badge label={alumno.nivel} color="#fff"/>
            </div>
            <p style={{ margin:0, opacity:0.65, fontSize:13 }}>{alumno.grado} · DNI {alumno.dni} · Nació el {alumno.nacimiento}</p>
          </div>
          <div style={{ display:"flex", gap:20, textAlign:"center" }}>

// VISTA: COMUNICACIÓN
// ══════════════════════════════════════════════════════════════════════════════
const Comunicacion = () => {
  const [tab, setTab] = useState("comunicados");

  // ── estado comunicados ──
  const [comLista, setComLista] = useState(COMUNICADOS_DATA);
  const [comModal, setComModal] = useState(false);
  const [comDetalle, setComDetalle] = useState(null);
  const [comForm, setComForm]   = useState({ titulo:"", cuerpo:"", destinatario:"Todos" });

  // ── estado mensajes ──
  const [msgLista, setMsgLista] = useState(MENSAJES_INIT);
  const [msgModal, setMsgModal] = useState(false);
  const [msgDetalle, setMsgDetalle] = useState(null);

  // composer state
  const [tipoEnvio, setTipoEnvio] = useState("individual"); // individual | curso | personalizado
  const [alumnoSel, setAlumnoSel] = useState("");           // id de alumno para individual
  const [cursoSel,  setCursoSel]  = useState("4°A");
  const [padresSel, setPadresSel] = useState([]);           // ids para personalizado
  const [busqPadre, setBusqPadre] = useState("");
  const [msgAsunto, setMsgAsunto] = useState("");
  const [msgCuerpo, setMsgCuerpo] = useState("");

  // ── helpers ──
  const GRADOS = [...new Set(ALUMNOS_DATA.filter(a=>a.estado==="activo").map(a=>a.grado))].sort();
  const alumnosActivos = ALUMNOS_DATA.filter(a=>a.estado==="activo");

  const getDestinatarios = () => {
    if (tipoEnvio==="individual") {
      const a = alumnosActivos.find(x=>String(x.id)===String(alumnoSel));
      return a ? [{ nombre:a.tutor, email:a.email, alumno:a.nombre }] : [];
    }
    if (tipoEnvio==="curso") {
      return alumnosActivos.filter(a=>a.grado===cursoSel).map(a=>({ nombre:a.tutor, email:a.email, alumno:a.nombre }));
    }
    return alumnosActivos.filter(a=>padresSel.includes(a.id)).map(a=>({ nombre:a.tutor, email:a.email, alumno:a.nombre }));
  };

  const destinatarios = getDestinatarios();

  const togglePadre = id => setPadresSel(prev => prev.includes(id) ? prev.filter(x=>x!==id) : [...prev, id]);

  const filtradosPadres = alumnosActivos.filter(a =>
    a.nombre.toLowerCase().includes(busqPadre.toLowerCase()) ||
    a.tutor.toLowerCase().includes(busqPadre.toLowerCase()) ||
    a.grado.toLowerCase().includes(busqPadre.toLowerCase())
  );

  const enviarMensaje = () => {
    if (!msgAsunto.trim() || !msgCuerpo.trim() || !destinatarios.length) return;
    const destLabel = tipoEnvio==="individual"
      ? `${destinatarios[0].nombre} (padre de ${destinatarios[0].alumno})`
      : tipoEnvio==="curso"
      ? `${cursoSel} – ${alumnosActivos.find(a=>a.grado===cursoSel)?.nivel}`
      : `${destinatarios.length} familias seleccionadas`;

    setMsgLista([{
      id: msgLista.length+1,
      asunto: msgAsunto,
      tipo: tipoEnvio,
      destLabel,
      destinatarios: destinatarios.map(d=>d.nombre),
      fecha: new Date().toLocaleDateString("es-AR"),
      cuerpo: msgCuerpo,
      leido: false
    }, ...msgLista]);

    setMsgModal(false);
    setMsgAsunto(""); setMsgCuerpo(""); setAlumnoSel(""); setPadresSel([]); setBusqPadre("");
  };

  const enviarComunicado = () => {
    const nuevo = { id:comLista.length+1, ...comForm, fecha:new Date().toLocaleDateString("es-AR"), estado:"enviado", autor:"Dirección" };
    setComLista([nuevo, ...comLista]);
    setComModal(false);
    setComForm({ titulo:"", cuerpo:"", destinatario:"Todos" });
  };

  const TIPO_MSG_COLOR = { individual:"#3B82F6", curso:"#8B5CF6", personalizado:"#E8734A" };
  const TIPO_MSG_LABEL = { individual:"Individual", curso:"Por curso", personalizado:"Personalizado" };
  const COM_COLOR      = { enviado:"#10B981", borrador:"#F59E0B" };

  return (
    <div>
      <SectionHeader title="Comunicación" subtitle="Comunicados institucionales y mensajes a familias" />

      <SubTabs
        tabs={[["comunicados","📢 Comunicados"],["mensajes","✉️ Mensajes a familias"]]}
        active={tab} onChange={setTab}
      />

      {/* ─────────────── TAB: COMUNICADOS ─────────────── */}
      {tab==="comunicados" && (
        <div>
          <div style={{ display:"flex", justifyContent:"flex-end", marginBottom:16 }}>
            <BtnPrimary onClick={()=>setComModal(true)}>+ Nuevo comunicado</BtnPrimary>
          </div>
          <div style={{ display:"flex", flexDirection:"column", gap:12 }}>
            {comLista.map(c=>(
              <Card key={c.id} className="card-hover" onClick={()=>setComDetalle(c)} style={{ padding:20 }}>
                <div style={{ display:"flex", alignItems:"flex-start", gap:14 }}>
                  <div style={{ width:44, height:44, borderRadius:12, background:COM_COLOR[c.estado]+"18", display:"flex", alignItems:"center", justifyContent:"center", fontSize:20, flexShrink:0 }}>
                    {c.estado==="enviado"?"📢":"📝"}
                  </div>
                  <div style={{ flex:1 }}>
                    <div style={{ display:"flex", alignItems:"center", gap:8, marginBottom:4, flexWrap:"wrap" }}>
                      <span style={{ fontSize:15, fontWeight:700, color:"#1A1535" }}>{c.titulo}</span>
                      <Badge label={c.estado==="enviado"?"Enviado":"Borrador"} color={COM_COLOR[c.estado]} small/>
                      <Badge label={c.destinatario} color="#3B82F6" small/>
                    </div>
                    <p style={{ margin:0, fontSize:13, color:"#6B7280", lineHeight:1.5, display:"-webkit-box", WebkitLineClamp:2, WebkitBoxOrient:"vertical", overflow:"hidden" }}>{c.cuerpo}</p>
                  </div>
                  <div style={{ textAlign:"right", flexShrink:0 }}>
                    <div style={{ fontSize:12, color:"#9CA3AF" }}>{c.fecha}</div>
                    <div style={{ fontSize:11, color:"#9CA3AF", marginTop:2 }}>por {c.autor}</div>
                  </div>
                </div>
              </Card>
            ))}
          </div>

          <Modal open={comModal} onClose={()=>setComModal(false)} title="Nuevo comunicado" width={600}>
            <FormRow label="Título">
              <Input value={comForm.titulo} onChange={e=>setComForm({...comForm,titulo:e.target.value})} placeholder="Ej: Acto por el Día de la Bandera" style={{ width:"100%" }}/>
            </FormRow>
            <FormRow label="Destinatarios">
              <Select value={comForm.destinatario} onChange={e=>setComForm({...comForm,destinatario:e.target.value})} style={{ width:"100%" }}>
                <option>Todos</option><option>Inicial</option><option>Primaria</option><option>Secundaria</option><option>Docentes</option>
              </Select>
            </FormRow>
            <FormRow label="Contenido">
              <Textarea value={comForm.cuerpo} onChange={e=>setComForm({...comForm,cuerpo:e.target.value})} placeholder="Escribir el contenido del comunicado…" rows={5}/>
            </FormRow>
            <div style={{ display:"flex", gap:10, justifyContent:"flex-end", marginTop:8 }}>
              <BtnSecondary onClick={()=>setComModal(false)}>Guardar borrador</BtnSecondary>
              <BtnPrimary onClick={enviarComunicado}>Publicar comunicado</BtnPrimary>
            </div>
          </Modal>

          <Modal open={!!comDetalle} onClose={()=>setComDetalle(null)} title={comDetalle?.titulo||""} width={560}>
            {comDetalle && (
              <div>
                <div style={{ display:"flex", gap:8, marginBottom:16 }}>
                  <Badge label={comDetalle.estado==="enviado"?"Publicado":"Borrador"} color={COM_COLOR[comDetalle.estado]}/>
                  <Badge label={`Para: ${comDetalle.destinatario}`} color="#3B82F6"/>
                  <Badge label={comDetalle.fecha} color="#9CA3AF"/>
                </div>
                <p style={{ fontSize:14, color:"#374151", lineHeight:1.75, margin:0 }}>{comDetalle.cuerpo}</p>
                <div style={{ marginTop:18, paddingTop:14, borderTop:"1px solid #F0EEF8", fontSize:12, color:"#9CA3AF" }}>Redactado por {comDetalle.autor}</div>
              </div>
            )}
          </Modal>
        </div>
      )}

      {/* ─────────────── TAB: MENSAJES ─────────────── */}
      {tab==="mensajes" && (
        <div>
          <div style={{ display:"flex", justifyContent:"flex-end", marginBottom:16 }}>
            <BtnPrimary onClick={()=>setMsgModal(true)}>✉️ Nuevo mensaje</BtnPrimary>
          </div>

          {msgLista.length===0
            ? <EmptyState icon="✉️" title="Sin mensajes enviados" sub="Los mensajes enviados a familias aparecerán aquí"/>
            : (
              <div style={{ display:"flex", flexDirection:"column", gap:10 }}>
                {msgLista.map(m=>(
                  <Card key={m.id} className="card-hover" onClick={()=>setMsgDetalle(m)} style={{ padding:20, borderLeft:`4px solid ${TIPO_MSG_COLOR[m.tipo]}` }}>
                    <div style={{ display:"flex", alignItems:"flex-start", gap:14 }}>
                      <div style={{ width:42, height:42, borderRadius:12, background:TIPO_MSG_COLOR[m.tipo]+"15", display:"flex", alignItems:"center", justifyContent:"center", fontSize:18, flexShrink:0 }}>
                        {m.tipo==="individual"?"👤":m.tipo==="curso"?"👥":"✅"}
                      </div>
                      <div style={{ flex:1, minWidth:0 }}>
                        <div style={{ display:"flex", alignItems:"center", gap:8, marginBottom:4, flexWrap:"wrap" }}>
                          <span style={{ fontSize:14, fontWeight:700, color:"#1A1535" }}>{m.asunto}</span>
                          <Badge label={TIPO_MSG_LABEL[m.tipo]} color={TIPO_MSG_COLOR[m.tipo]} small/>
                        </div>
                        <div style={{ fontSize:12, color:"#6B7280", marginBottom:4 }}>
                          📧 Para: <strong>{m.destLabel}</strong>
                        </div>
                        <p style={{ margin:0, fontSize:12, color:"#9CA3AF", lineHeight:1.4, display:"-webkit-box", WebkitLineClamp:1, WebkitBoxOrient:"vertical", overflow:"hidden" }}>{m.cuerpo}</p>
                      </div>
                      <div style={{ textAlign:"right", flexShrink:0 }}>
                        <div style={{ fontSize:12, color:"#9CA3AF" }}>{m.fecha}</div>
                        <div style={{ fontSize:11, marginTop:4 }}>
                          <Badge label={`${m.destinatarios.length} destinatario${m.destinatarios.length>1?"s":""}`} color="#6B7280" small/>
                        </div>
                      </div>
                    </div>
                  </Card>
                ))}
              </div>
            )

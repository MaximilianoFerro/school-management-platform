// APP SHELL
// ══════════════════════════════════════════════════════════════════════════════
const NAV = [
  { id:"dashboard",     icon:"⊞",  label:"Panel general" },
  { id:"alumnos",       icon:"🎒", label:"Alumnos" },
  { id:"docentes",      icon:"👩‍🏫",label:"Docentes" },
  { id:"comunicacion",   icon:"✉️", label:"Comunicación" },
  { id:"agenda",        icon:"📅", label:"Agenda" },
  { id:"reportes",      icon:"📊", label:"Reportes" },
  null, // divider
  { id:"configuracion", icon:"⚙️", label:"Configuración" },
];

export default function App() {
  const [vista,      setVista]      = useState("dashboard");
  const [alumnoSel,  setAlumnoSel]  = useState(null);
  const [collapsed,  setCollapsed]  = useState(false);

  const handleNav = id => { setVista(id); setAlumnoSel(null); };

  const isActive = id => vista===id || (vista==="alumnoDetalle" && id==="alumnos") || (vista==="comunicacion" && id==="comunicacion");

  const renderVista = () => {
    if (vista==="alumnoDetalle" && alumnoSel) return <AlumnoDetalle alumno={alumnoSel} onBack={()=>setVista("alumnos")}/>;
    switch(vista) {
      case "dashboard":   return <Dashboard setVista={setVista} setAlumnoSel={setAlumnoSel}/>;
      case "alumnos":     return <Alumnos setVista={setVista} setAlumnoSel={setAlumnoSel}/>;
      case "docentes":    return <Docentes/>;
      case "comunicacion": return <Comunicacion/>;
      case "agenda":      return <Agenda/>;
      case "reportes":    return <Reportes/>;
      case "configuracion":return <Configuracion/>;
      default: return null;
    }
  };

  const VISTA_LABEL = { dashboard:"Panel general", alumnos:"Alumnos", docentes:"Docentes", comunicacion:"Comunicación", agenda:"Agenda", reportes:"Reportes", configuracion:"Configuración", alumnoDetalle:"Legajo del alumno" };

  return (
    <div style={{ display:"flex", height:"100vh", background:"#F4F3FB", fontFamily:"'DM Sans', sans-serif", fontSize:14 }}>
      <GlobalStyles/>

      {/* ── SIDEBAR ── */}
      <aside style={{ width: collapsed?68:230, background:"#12102A", display:"flex", flexDirection:"column", transition:"width 0.22s ease", flexShrink:0, overflow:"hidden" }}>
        {/* Logo */}
        <div style={{ padding: collapsed?"18px 16px":"20px 18px 16px", borderBottom:"1px solid rgba(255,255,255,0.07)" }}>
          <div style={{ display:"flex", alignItems:"center", gap:10 }}>
            <div style={{ width:36, height:36, borderRadius:10, background:"linear-gradient(135deg,#7C5CBF,#4C3D9E)", display:"flex", alignItems:"center", justifyContent:"center", fontSize:18, flexShrink:0 }}>🏫</div>
            {!collapsed && (
              <div>
                <div style={{ fontSize:15, fontWeight:800, color:"#fff", lineHeight:1.1, letterSpacing:"-0.3px" }}>EduGestión</div>
                <div style={{ fontSize:9, color:"rgba(255,255,255,0.35)", letterSpacing:"1.2px", textTransform:"uppercase" }}>Admin · San Martín</div>
              </div>
            )}
          </div>
        </div>

        {/* Nav */}
        <nav style={{ flex:1, padding:"10px 8px", overflowY:"auto" }}>
          {NAV.map((item, i) => {
            if (!item) return <div key={i} style={{ height:1, background:"rgba(255,255,255,0.07)", margin:"8px 4px" }}/>;
            const active = isActive(item.id);
            return (
              <button key={item.id} className="nav-btn" onClick={()=>handleNav(item.id)}
                style={{ width:"100%", display:"flex", alignItems:"center", gap:10, padding: collapsed?"10px 14px":"10px 12px", borderRadius:9, border:"none", cursor:"pointer", marginBottom:2, background: active?"rgba(124,92,191,0.3)":"transparent", color: active?"#C4B9F0":"rgba(255,255,255,0.55)", textAlign:"left", transition:"background 0.15s, color 0.15s" }}>
                <span style={{ fontSize:17, flexShrink:0, opacity: active?1:0.75 }}>{item.icon}</span>
                {!collapsed && <span style={{ fontSize:13, fontWeight: active?700:500 }}>{item.label}</span>}
                {active && !collapsed && <div style={{ marginLeft:"auto", width:5, height:5, borderRadius:"50%", background:"#9B7DE8" }}/>}
              </button>
            );
          })}
        </nav>

        {/* Footer */}
        <div style={{ padding:"12px 8px", borderTop:"1px solid rgba(255,255,255,0.07)" }}>
          <button onClick={()=>setCollapsed(!collapsed)} style={{ width:"100%", background:"rgba(255,255,255,0.05)", border:"none", borderRadius:8, padding:"8px", color:"rgba(255,255,255,0.35)", cursor:"pointer", fontSize:12, display:"flex", alignItems:"center", justifyContent: collapsed?"center":"flex-end", gap:6 }}>
            {!collapsed && <span>Colapsar</span>}
            <span>{collapsed?"▶":"◀"}</span>
          </button>
        </div>
      </aside>

      {/* ── MAIN ── */}
      <div style={{ flex:1, display:"flex", flexDirection:"column", overflow:"hidden" }}>
        {/* Topbar */}
        <header style={{ background:"#fff", borderBottom:"1px solid #EEE9FC", padding:"0 28px", height:58, display:"flex", alignItems:"center", justifyContent:"space-between", flexShrink:0 }}>
          <div style={{ display:"flex", alignItems:"center", gap:8, fontSize:13, color:"#9CA3AF" }}>
            <span>Inicio</span>
            <span>›</span>
            <span style={{ color:"#1A1535", fontWeight:600 }}>{VISTA_LABEL[vista]||vista}</span>
          </div>
          <div style={{ display:"flex", alignItems:"center", gap:14 }}>
            <div style={{ display:"flex", alignItems:"center", gap:6 }}>
              <div style={{ width:8, height:8, borderRadius:"50%", background:"#10B981" }}/>
              <span style={{ fontSize:12, color:"#6B7280" }}>Ciclo 2025 activo</span>
            </div>
            <div style={{ width:1, height:20, background:"#F0EEF8" }}/>
            <div style={{ display:"flex", alignItems:"center", gap:8 }}>
              <div style={{ textAlign:"right" }}>
                <div style={{ fontSize:13, fontWeight:700, color:"#1A1535" }}>Patricia Morales</div>
                <div style={{ fontSize:10, color:"#9CA3AF" }}>Directora · Administrador</div>
              </div>
              <Avatar ini="PM" size={34}/>
            </div>
          </div>
        </header>

        {/* Content */}
        <main style={{ flex:1, overflowY:"auto", padding:"28px 32px" }}>
          {renderVista()}
        </main>
      </div>
    </div>
  );
}

// VISTA: AGENDA
// ══════════════════════════════════════════════════════════════════════════════
const Agenda = () => {
  const [modal, setModal]   = useState(false);
  const [eventos, setEventos] = useState(EVENTOS_DATA);
  const [form, setForm]     = useState({ titulo:"", fecha:"", hora:"", tipo:"evento", nivel:"Todos", desc:"" });

  const agregar = () => {
    setEventos([...eventos, { id: eventos.length+1, ...form }]);
    setModal(false);
    setForm({ titulo:"", fecha:"", hora:"", tipo:"evento", nivel:"Todos", desc:"" });
  };

  const sorted = [...eventos].sort((a,b)=>a.fecha.localeCompare(b.fecha));

  // Agrupar por mes
  const grupos = sorted.reduce((acc, ev) => {
    const mes = ev.fecha.substring(0,7);
    if (!acc[mes]) acc[mes] = [];
    acc[mes].push(ev);
    return acc;
  }, {});

  const MESES = ["Enero","Febrero","Marzo","Abril","Mayo","Junio","Julio","Agosto","Septiembre","Octubre","Noviembre","Diciembre"];

  return (
    <div>
      <SectionHeader title="Agenda Institucional" subtitle="Eventos y fechas importantes del ciclo lectivo"
        action={<BtnPrimary onClick={()=>setModal(true)}>+ Nuevo evento</BtnPrimary>}/>

      {Object.entries(grupos).map(([mes, evs])=>{
        const [year, m] = mes.split("-");
        return (
          <div key={mes} style={{ marginBottom:28 }}>
            <div style={{ fontSize:13, fontWeight:800, color:"#4C3D9E", textTransform:"uppercase", letterSpacing:2, marginBottom:12 }}>
              {MESES[parseInt(m)-1]} {year}
            </div>
            <div style={{ display:"flex", flexDirection:"column", gap:10 }}>
              {evs.map(ev=>(
                <Card key={ev.id} style={{ padding:"16px 20px" }}>
                  <div style={{ display:"flex", alignItems:"center", gap:16 }}>
                    <div style={{ textAlign:"center", width:44, flexShrink:0 }}>
                      <div style={{ fontSize:22, fontWeight:800, color:"#1A1535", lineHeight:1 }}>{ev.fecha.split("-")[2]}</div>
                      <div style={{ fontSize:10, color:"#9CA3AF", textTransform:"uppercase", letterSpacing:0.5 }}>{MESES[parseInt(ev.fecha.split("-")[1])-1].slice(0,3)}</div>
                    </div>
                    <div style={{ width:4, height:44, background:TIPO_EVENTO[ev.tipo], borderRadius:4, flexShrink:0 }}/>
                    <div style={{ flex:1 }}>
                      <div style={{ fontSize:14, fontWeight:700, color:"#1A1535" }}>{ev.titulo}</div>
                      <div style={{ fontSize:12, color:"#9CA3AF", marginTop:2 }}>{ev.desc}</div>
                    </div>
                    <div style={{ display:"flex", gap:8, alignItems:"center" }}>
                      {ev.hora!=="—" && <span style={{ fontSize:12, color:"#6B7280", background:"#F5F4FC", borderRadius:8, padding:"3px 10px" }}>⏰ {ev.hora} hs</span>}
                      <Badge label={TIPO_LABEL[ev.tipo]} color={TIPO_EVENTO[ev.tipo]} small/>
                      <Badge label={ev.nivel} color={NIVEL_COLOR[ev.nivel]||"#6B7280"} small/>
                    </div>
                  </div>
                </Card>
              ))}
            </div>
          </div>
        );
      })}

      <Modal open={modal} onClose={()=>setModal(false)} title="Nuevo evento" width={520}>
        <FormRow label="Título del evento">
          <Input value={form.titulo} onChange={e=>setForm({...form,titulo:e.target.value})} placeholder="Ej: Acto por el Día del Maestro" style={{ width:"100%" }}/>
        </FormRow>
        <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:16 }}>
          <FormRow label="Fecha">
            <Input value={form.fecha} onChange={e=>setForm({...form,fecha:e.target.value})} placeholder="AAAA-MM-DD" style={{ width:"100%" }}/>
          </FormRow>
          <FormRow label="Hora (opcional)">
            <Input value={form.hora} onChange={e=>setForm({...form,hora:e.target.value})} placeholder="Ej: 09:00" style={{ width:"100%" }}/>
          </FormRow>
          <FormRow label="Tipo">
            <Select value={form.tipo} onChange={e=>setForm({...form,tipo:e.target.value})} style={{ width:"100%" }}>
              <option value="acto">Acto</option>
              <option value="reunion">Reunión</option>
              <option value="evaluacion">Evaluación</option>
              <option value="evento">Evento</option>
              <option value="institucional">Institucional</option>
            </Select>
          </FormRow>
          <FormRow label="Nivel">
            <Select value={form.nivel} onChange={e=>setForm({...form,nivel:e.target.value})} style={{ width:"100%" }}>
              <option>Todos</option><option>Inicial</option><option>Primaria</option><option>Secundaria</option>
            </Select>
          </FormRow>
        </div>
        <FormRow label="Descripción">
          <Textarea value={form.desc} onChange={e=>setForm({...form,desc:e.target.value})} placeholder="Detalles del evento…" rows={3}/>
        </FormRow>
        <div style={{ display:"flex", gap:10, justifyContent:"flex-end", marginTop:8 }}>
          <BtnSecondary onClick={()=>setModal(false)}>Cancelar</BtnSecondary>
          <BtnPrimary onClick={agregar}>Agregar evento</BtnPrimary>
        </div>
      </Modal>
    </div>
  );
};


const avg = arr => {
  const nums = arr.filter(x => typeof x === "number");
  if (!nums.length) return null;
  return parseFloat((nums.reduce((a, b) => a + b, 0) / nums.length).toFixed(1));
};
const pct = (a, b) => Math.round((a / b) * 100);

const AVATAR_COLORS = ["#E8734A","#3B82F6","#10B981","#8B5CF6","#F59E0B","#EC4899","#06B6D4","#84CC16"];
const avatarColor = ini => AVATAR_COLORS[ini.charCodeAt(0) % AVATAR_COLORS.length];

const NIVEL_COLOR  = { Inicial:"#F59E0B", Primaria:"#3B82F6", Secundaria:"#8B5CF6" };
const TIPO_EVENTO  = { acto:"#8B5CF6", reunion:"#3B82F6", evaluacion:"#EF4444", evento:"#10B981", institucional:"#6B7280" };
const TIPO_LABEL   = { acto:"Acto", reunion:"Reunión", evaluacion:"Evaluación", evento:"Evento", institucional:"Institucional" };

const promAlumno = id => {
  const notas = NOTAS_DATA[id];
  if (!notas) return null;
  const nums = Object.values(notas)
    .flatMap(v => typeof v === "object" && !Array.isArray(v) ? Object.values(v).flat() : v)
    .filter(x => typeof x === "number");
  return nums.length ? parseFloat((nums.reduce((a,b)=>a+b,0)/nums.length).toFixed(1)) : null;
};

const getAlertaAlumno = a => {
  const p = promAlumno(a.id);
  const aus = ASISTENCIA_DATA[a.id]?.ausentes || 0;
  const alerts = [];
  if (p !== null && p < 6) alerts.push({ label: `Prom. ${p}`, color:"#EF4444" });
  if (aus >= 7) alerts.push({ label:`${aus} ausencias`, color:"#E8734A" });
  return alerts;
};

